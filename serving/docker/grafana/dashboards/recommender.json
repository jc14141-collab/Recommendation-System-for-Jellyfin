{
  "__inputs": [],
  "__requires": [
    {"type": "grafana", "id": "grafana", "name": "Grafana", "version": "11.0.0"},
    {"type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0"},
    {"type": "panel", "id": "timeseries", "name": "Time series", "version": ""},
    {"type": "panel", "id": "stat", "name": "Stat", "version": ""}
  ],
  "title": "Jellyfin Recommender",
  "uid": "jellyfin-recommender-v1",
  "description": "Multiworker ONNX serving: latency, fallback rate, throughput",
  "tags": ["jellyfin", "ml", "recommender"],
  "timezone": "browser",
  "schemaVersion": 38,
  "refresh": "10s",
  "time": {"from": "now-30m", "to": "now"},
  "templating": {
    "list": [
      {
        "name": "env",
        "type": "custom",
        "label": "Environment",
        "query": "serving_staging,serving_canary,serving_prod",
        "current": {"selected": true, "text": "serving_prod", "value": "serving_prod"},
        "options": [
          {"selected": false, "text": "serving_staging", "value": "serving_staging"},
          {"selected": false, "text": "serving_canary",  "value": "serving_canary"},
          {"selected": true,  "text": "serving_prod",    "value": "serving_prod"}
        ],
        "hide": 0,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate (req/s) — $env",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "sum(rate(recommend_requests_total{job=\"$env\"}[1m])) by (mode)",
          "legendFormat": "{{mode}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}
      }
    },
    {
      "id": 2,
      "title": "Fallback Rate (%) — $env",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "100 * sum(rate(recommend_requests_total{mode=\"fallback\",job=\"$env\"}[1m])) / (sum(rate(recommend_requests_total{job=\"$env\"}[1m])) > 0)",
          "legendFormat": "fallback %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 30}
            ]
          },
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 3,
      "title": "Latency — p50 / p95 / p99 (ms) — $env",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 8},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "histogram_quantile(0.50, sum(rate(recommend_request_latency_seconds_bucket{mode=\"model\",job=\"$env\"}[1m])) by (le)) * 1000",
          "legendFormat": "p50 (ms)",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "histogram_quantile(0.95, sum(rate(recommend_request_latency_seconds_bucket{mode=\"model\",job=\"$env\"}[1m])) by (le)) * 1000",
          "legendFormat": "p95 (ms)",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "histogram_quantile(0.99, sum(rate(recommend_request_latency_seconds_bucket{mode=\"model\",job=\"$env\"}[1m])) by (le)) * 1000",
          "legendFormat": "p99 (ms)",
          "refId": "C"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "1000",
          "legendFormat": "1s threshold",
          "refId": "D"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": {"lineWidth": 2}
        },
        "overrides": [
          {
            "matcher": {"id": "byName", "options": "1s threshold"},
            "properties": [
              {"id": "color", "value": {"mode": "fixed", "fixedColor": "red"}},
              {"id": "custom.lineStyle", "value": {"fill": "dash", "dash": [8, 4]}}
            ]
          }
        ]
      }
    },
    {
      "id": 4,
      "title": "Fallback Breakdown by Reason (req/s) — $env",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "sum(rate(fallback_used_total{job=\"$env\"}[1m])) by (reason)",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}
      }
    },
    {
      "id": 5,
      "title": "Avg Candidate Count per Request — $env",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "sum(rate(recommend_candidate_count_sum{job=\"$env\"}[1m])) / sum(rate(recommend_candidate_count_count{job=\"$env\"}[1m]))",
          "legendFormat": "avg candidates",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "short", "custom": {"lineWidth": 2}}
      }
    },
    {
      "id": 6,
      "title": "Current Request Rate — $env",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "sum(rate(recommend_requests_total{job=\"$env\"}[1m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "id": 7,
      "title": "Current p95 Latency — $env",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "histogram_quantile(0.95, sum(rate(recommend_request_latency_seconds_bucket{mode=\"model\",job=\"$env\"}[5m])) by (le)) * 1000",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 1000},
              {"color": "red", "value": 5000}
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Current Fallback Rate — $env",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "100 * sum(rate(recommend_requests_total{mode=\"fallback\",job=\"$env\"}[5m])) / (sum(rate(recommend_requests_total{job=\"$env\"}[5m])) > 0)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 10},
              {"color": "red", "value": 30}
            ]
          }
        }
      }
    },
    {
      "id": 9,
      "title": "Total Requests (last 5m) — $env",
      "type": "stat",
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 24},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "sum(increase(recommend_requests_total{job=\"$env\"}[5m]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "short"}}
    },
    {
      "id": 10,
      "title": "CPU Usage (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "100 - (avg(rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
          "legendFormat": "CPU %",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {"color": "green", "value": null},
              {"color": "yellow", "value": 70},
              {"color": "red", "value": 90}
            ]
          },
          "custom": {"lineWidth": 2}
        }
      }
    },
    {
      "id": 11,
      "title": "User Clicks by Rank — $env",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "sum(rate(user_click_total{job=\"$env\"}[5m])) by (rank)",
          "legendFormat": "rank {{rank}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}
      }
    },
    {
      "id": 12,
      "title": "All Environments — Request Rate Comparison",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 40},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "sum(rate(recommend_requests_total{job=\"serving_staging\"}[1m]))",
          "legendFormat": "staging",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "sum(rate(recommend_requests_total{job=\"serving_canary\"}[1m]))",
          "legendFormat": "canary",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "sum(rate(recommend_requests_total{job=\"serving_prod\"}[1m]))",
          "legendFormat": "prod",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "reqps", "custom": {"lineWidth": 2}}
      }
    },
    {
      "id": 13,
      "title": "All Environments — Fallback Rate Comparison (%)",
      "type": "timeseries",
      "gridPos": {"h": 8, "w": 24, "x": 0, "y": 48},
      "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
      "targets": [
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "100 * sum(rate(recommend_requests_total{mode=\"fallback\",job=\"serving_staging\"}[1m])) / (sum(rate(recommend_requests_total{job=\"serving_staging\"}[1m])) > 0)",
          "legendFormat": "staging fallback %",
          "refId": "A"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "100 * sum(rate(recommend_requests_total{mode=\"fallback\",job=\"serving_canary\"}[1m])) / (sum(rate(recommend_requests_total{job=\"serving_canary\"}[1m])) > 0)",
          "legendFormat": "canary fallback %",
          "refId": "B"
        },
        {
          "datasource": {"type": "prometheus", "uid": "prometheus-jellyfin"},
          "expr": "100 * sum(rate(recommend_requests_total{mode=\"fallback\",job=\"serving_prod\"}[1m])) / (sum(rate(recommend_requests_total{job=\"serving_prod\"}[1m])) > 0)",
          "legendFormat": "prod fallback %",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {"lineWidth": 2}
        }
      }
    }
  ]
}
